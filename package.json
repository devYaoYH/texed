{
  "name": "tex-sidecar",
  "version": "0.1.0",
  "description": "Local desktop TeX editor with side-by-side PDF preview and file tree navigation.",
  "main": "src/main.cjs",
  "private": true,
  "scripts": {
    "dev": "TEX_SIDECAR_DEV_RELOAD=1 electron .",
    "start": "electron .",
    "package": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "local.tex-sidecar",
    "productName": "TeX Sidecar",
    "files": [
      "src/**/*",
      "node_modules/ace-builds/src-min-noconflict/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "ace-builds": "^1.44.0"
  }
}
